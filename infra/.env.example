# =====================================================================
# OmniJob — local dev environment
# Copy to `.env` and edit. Never commit `.env`.
# =====================================================================

# ---- infra/docker-compose ----
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
REDIS_PORT=6379

# ---- apps/api ----
PORT=3000
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
SQLITE_PATH=./data/omnijob.sqlite
JOBS_COLLECTION=jobs
USERS_COLLECTION=users
EMBEDDING_DIM=1536

# ---- apps/crawler ----
REDIS_URL=redis://localhost:6379
API_URL=http://localhost:3000
SEED_FILE=./seeds.txt
WORKER_COUNT=4
MAX_DEPTH=2
PER_DOMAIN_PARALLELISM=2
PER_DOMAIN_DELAY_MS=1500
USER_AGENT=OmniJobBot/0.1 (+https://omnijob.example/bot)
